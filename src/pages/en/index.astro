---
import Layout from '../../layouts/Layout.astro';
import AppCard from '../../components/AppCard.astro';
import Button from '../../components/Button.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import { useTranslations } from '../../i18n/utils';
import { fetchLatestRelease } from '../../utils/github';

const t = useTranslations('en');

const release = await fetchLatestRelease('cybernattor/bit-hub', 'en');

const title = 'bit Technologies — Ecosystem of convenient apps';
const description = 'bit Technologies develops native, fast, and private Android applications. No telemetry, no ads.';

const schema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "bit Tecnologies",
	"url": "https://cybernattor.github.io/en",
	"description": description
};
---

<Layout title={title} description={description} schema={schema}>
	<!-- Hero Section -->
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300">
		<div class="container mx-auto px-4 py-16 md:py-24">
			<div class="text-center max-w-4xl mx-auto z-10 relative">
				<div class="mb-6" style="view-transition-name: hero-logo;">
					<img src="/favicon.svg" alt="bit Tecnologies" class="w-20 h-20 mx-auto mb-6 drop-shadow-lg" />
				</div>
				<h1 class="text-4xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-emerald-600 dark:from-blue-500 dark:to-emerald-500 bg-clip-text text-transparent animate-pulse font-display drop-shadow-sm">
					bit Tecnologies
				</h1>
				<p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 mb-8 max-w-2xl mx-auto leading-relaxed font-light transition-colors">
					{t('hero.subtitle')}
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
					<Button href="#download" variant="primary" download>
						<svg class="w-5 h-5 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
						</svg>
						<span>{t('hero.download_hub')}</span>
					</Button>
					<Button href="/en/about" variant="outline">
						{t('nav.about')}
					</Button>
				</div>
			</div>
		</div>
		<!-- Decorative gradient -->
		<div class="absolute inset-0 bg-gradient-to-t from-blue-500/5 to-transparent pointer-events-none"></div>
		<!-- Animated background elements -->
		<div class="absolute top-20 left-10 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl animate-pulse"></div>
		<div class="absolute bottom-20 right-10 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
	</section>

	<!-- App Showcase -->
	<section id="apps" class="py-16 md:py-24 bg-slate-50/50 dark:bg-slate-900/50 transition-colors duration-300">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900 dark:text-white font-display">{t('home.apps')}</h2>
				<p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-light transition-colors">
					{t('home.apps_subtitle')}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
				<!-- bit Hub Card -->
        <AppCard
          href="/en/bit-hub"
          name="bit Hub"
          status={{ label: "Beta", color: "emerald" }}
          description={t('app.bithub_desc')}
          requirements="Android 10+"
          size={release?.size || '2.4 MB'}
          iconImage="/favicon.svg"
        />

				<!-- bit Delta Card -->
        <AppCard
          href="/en/bit-delta"
          name="bit Delta"
          status={{ label: "In Development", color: "blue" }}
          description={t('app.bitdelta_desc')}
          requirements="Android 12+"
          size={release?.size || '~5 MB'}
          iconBgColor="from-purple-500 to-pink-500"
        >
          <svg slot="icon" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13.5,5.5C14.59,5.5 15.5,4.58 15.5,3.5C15.5,2.38 14.59,1.5 13.5,1.5C12.39,1.5 11.5,2.38 11.5,3.5C11.5,4.58 12.39,5.5 13.5,5.5M9.89,19.38L10.89,15L13,17V23H15V15.5L12.89,13.5L13.5,10.5C14.79,12 16.79,13 19,13V11C17.09,11 15.5,10 14.69,8.58L13.69,7C13.29,6.38 12.69,6 12,6C11.69,6 11.5,6.08 11.19,6.19L6,8.28V13H8V9.58L9.79,8.88L8.19,17L3.29,16L2.89,18L9.89,19.38Z"/>
          </svg>
        </AppCard>

				<!-- bit Record Card -->
        <AppCard
          href="/en/bit-record"
          name="bit Record"
          status={{ label: "Planning", color: "yellow" }}
          description={t('app.bitrecord_desc')}
          requirements="Android 11+"
          size="~3 MB"
          iconBgColor="from-red-500 to-orange-500"
        >
          <svg slot="icon" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17,10.5V7A1,1 0 0,0 16,6H4A1,1 0 0,0 3,7V17A1,1 0 0,0 4,18H16A1,1 0 0,0 17,17V13.5L21,17.5V6.5L17,10.5Z"/>
          </svg>
        </AppCard>
			</div>
		</div>
	</section>

	<!-- Android Compatibility -->
	<section id="compatibility" class="py-16 md:py-24 bg-white dark:bg-slate-950 transition-colors duration-300">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900 dark:text-white font-display">{t('home.compatibility')}</h2>
					<p class="text-slate-600 dark:text-slate-400 font-light transition-colors">
						{t('home.compatibility_subtitle')}
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <FeatureCard title={t('home.requirements_title')} iconColor="text-green-500">
            <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9,11H7V13H9V11M13,11H11V13H13V11M17,11H15V13H17V11M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V6A2,2 0 0,0 19,4M19,20H5V9H19V20Z"/>
            </svg>
						<ul class="space-y-2 text-slate-600 dark:text-slate-300 transition-colors">
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-500 dark:text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Android 10 (API 29) and higher</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-500 dark:text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>2 GB RAM (recommended)</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-500 dark:text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>ARMv7 or ARM64 architecture</span>
							</li>
						</ul>
          </FeatureCard>

          <FeatureCard title={t('home.testing_title')} iconColor="text-blue-500">
            <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
            </svg>
						<ul class="space-y-2 text-slate-600 dark:text-slate-300 transition-colors">
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-blue-500 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Tested on Android 16</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-blue-500 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Support for budget devices</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-blue-500 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Optimization for low-end hardware</span>
							</li>
						</ul>
          </FeatureCard>
				</div>
			</div>
		</div>
	</section>

	<!-- Download CTA -->
	<section id="download" class="py-16 md:py-24 bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300 border-t border-slate-200 dark:border-slate-800">
		<div class="container mx-auto px-4">
			<div class="text-center max-w-3xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-bold mb-6 text-slate-900 dark:text-white font-display">{t('home.cta_title')}</h2>
				<p class="text-lg text-slate-600 dark:text-slate-300 mb-8 font-light transition-colors">
					{t('home.cta_desc')}
				</p>
        <Button href="#download" variant="primary" download>
					<svg class="w-6 h-6 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
						<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
					</svg>
					<span>Download bit Hub</span>
        </Button>
				<p class="text-sm text-slate-500 mt-4">
					File size: {release?.size || '~2.4 MB'} • Requires Android 10+ • {t('home.cta_file_info')}
				</p>
			</div>
		</div>
	</section>
</Layout>
