---
// src/components/Header.astro
import ThemeToggle from './ThemeToggle.astro';
import DynamicLanguagePicker from './DynamicLanguagePicker.astro';
import { Image } from 'astro:assets';
import favicon from '../../public/favicon.svg';
import { getLangFromUrl, useTranslations, translatePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translate = translatePath(Astro.url);
---

<header class="border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md sticky top-0 z-50 transition-colors duration-300">
  <nav class="container mx-auto px-4 py-3 sm:py-4">
    <div class="flex items-center justify-between">
      <a href={translate('/')} class="flex flex-row items-center space-x-2">
        <Image src={favicon} alt="bit Tecnologies" class="w-7 h-7 sm:w-8 sm:h-8" />
        <span class="text-lg sm:text-xl font-bold font-display bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">
          bit Tecnologies
        </span>
      </a>
      <div class="hidden md:flex items-center space-x-4 sm:space-x-6">
        <a href={translate('/about')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 animated-line text-sm sm:text-base" data-i18n="nav.about">{t('nav.about')}</a>
        <a href={translate('/#compatibility')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 animated-line text-sm sm:text-base" data-i18n="nav.compatibility">{t('nav.compatibility')}</a>
        <a href={translate('/#download')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 animated-line text-sm sm:text-base" data-i18n="nav.download">{t('nav.download')}</a>
        <DynamicLanguagePicker />
        <ThemeToggle />
      </div>
      <!-- Mobile menu buttons -->
      <div class="md:hidden flex items-center space-x-2 mobile-menu-fixed">
        <div class="p-1 relative z-[61]">
          <DynamicLanguagePicker />
        </div>
        <div class="p-1 relative z-[61]">
          <ThemeToggle />
        </div>
        <button class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors min-h-[44px] min-w-[44px] p-2 relative z-[61] no-select focus-visible" id="mobile-menu-btn" aria-label="Toggle menu">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden mt-3 sm:mt-4 pb-3 sm:pb-4 border-t border-slate-100 dark:border-slate-800 transition-all duration-300 transform origin-top mobile-menu-animate">
      <div class="flex flex-col space-y-1 sm:space-y-2 pt-3 sm:pt-4">
        <a href={translate('/about')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 py-2 sm:py-3 text-sm sm:text-base block" data-i18n="nav.about">{t('nav.about')}</a>
        <a href={translate('/#compatibility')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 py-2 sm:py-3 text-sm sm:text-base block" data-i18n="nav.compatibility">{t('nav.compatibility')}</a>
        <a href={translate('/#download')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 py-2 sm:py-3 text-sm sm:text-base block" data-i18n="nav.download">{t('nav.download')}</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Script runs once on initial load and stays active across View Transitions
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn && menu) {
      // Clean up old listeners (for ViewTransitions)
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);

      // Handle both click and touch events for mobile compatibility
      const handleMenuToggle = (e: MouseEvent | TouchEvent) => {
        e.preventDefault();

        if (menu.classList.contains('hidden')) {
          // Show menu with animation
          menu.classList.remove('hidden');
          menu.classList.add('scale-y-0', 'opacity-0');
          // Force reflow
          menu.offsetHeight;
          menu.classList.remove('scale-y-0', 'opacity-0');
          menu.classList.add('scale-y-100', 'opacity-100');
        } else {
          // Hide menu with animation
          menu.classList.remove('scale-y-100', 'opacity-100');
          menu.classList.add('scale-y-0', 'opacity-0');
          setTimeout(() => {
            menu.classList.add('hidden');
            menu.classList.remove('scale-y-0', 'opacity-0');
          }, 300);
        }
      };

      newBtn.addEventListener('click', handleMenuToggle);
      newBtn.addEventListener('touchend', handleMenuToggle);

      // Close mobile menu when clicking on a link
      const menuLinks = document.querySelectorAll('#mobile-menu a');
      menuLinks.forEach(link => {
        const newLink = link.cloneNode(true);
        link.parentNode?.replaceChild(newLink, link);

        const handleLinkClick = (e: MouseEvent | TouchEvent) => {
          // Hide menu with animation
          menu.classList.remove('scale-y-100', 'opacity-100');
          menu.classList.add('scale-y-0', 'opacity-0');
          setTimeout(() => {
            menu.classList.add('hidden');
            menu.classList.remove('scale-y-0', 'opacity-0');
          }, 300);
        };

        newLink.addEventListener('click', handleLinkClick);
        newLink.addEventListener('touchend', handleLinkClick);
      });
    }
  }

  // Setup on initial load
  setupMobileMenu();

  // Setup after each View Transition
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
