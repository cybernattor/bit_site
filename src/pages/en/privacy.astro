---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const title = 'Privacy Policy — bit Tecnologies';
const description = 'Privacy policy of bit Tecnologies. Find out how we protect your data and ensure privacy in our apps.';
const image = '/og-bit-hub.png';
---

<Layout title={title} description={description} image={image}>
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300">
		<div class="container mx-auto px-4 py-12 sm:py-16 md:py-24">
			<div class="max-w-4xl mx-auto z-10 relative">
				<!-- Header -->
				<div class="text-center mb-8 sm:mb-12">
					<img src="/favicon.svg" alt="bit Tecnologies" class="w-16 h-16 sm:w-20 sm:h-20 mx-auto mb-4 sm:mb-6 drop-shadow-md" />
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4 bg-gradient-to-r from-blue-600 to-emerald-600 dark:from-blue-500 dark:to-emerald-500 bg-clip-text text-transparent font-display drop-shadow-sm">
						Privacy Policy
					</h1>
					<p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 font-light transition-colors">
						Last updated: March 9, 2026
					</p>
				</div>

				<!-- Content -->
				<div class="glass-effect rounded-xl p-4 sm:p-6 md:p-8 mb-6 sm:mb-8 bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 backdrop-blur-md shadow-xl transition-colors">
					<div class="max-w-none">
						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 font-display transition-colors">General Provisions</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							bit Tecnologies ("we", "us") respects your privacy and is committed to protecting the personal data of our application users.
							This privacy policy explains what data we collect, how we use it, and how we protect it.
						</p>

						<h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4 mt-8 font-display transition-colors">Data Collection</h2>

						<h3 class="text-lg sm:text-xl font-semibold text-slate-800 dark:text-white mb-2 sm:mb-3 mt-4 sm:mt-6 font-display transition-colors">bit Hub</h3>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-3 sm:mb-4 font-light transition-colors">bit Hub may collect the following technical data:</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li>Anonymous app usage data</li>
							<li>Technical device information (OS type, version)</li>
							<li>Crash and error data for stability improvement</li>
							<li>Anonymous feature usage statistics</li>
							<li>User preferences and settings</li>
							<li>Analytics data on feature usage</li>
						</ul>

						<h3 class="text-lg sm:text-xl font-semibold text-slate-800 dark:text-white mb-2 sm:mb-3 mt-4 sm:mt-6 font-display transition-colors">bit Delta (under development)</h3>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-3 sm:mb-4 font-light transition-colors">The following data collection is planned:</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li>Email for notifications and support (only with consent)</li>
							<li>Purchase and transaction history</li>
							<li>User preferences and settings</li>
							<li>Analytics data on feature usage</li>
						</ul>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Data Usage</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							Collected data is used for the following purposes:
						</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li>Improving app quality and stability</li>
							<li>Analyzing feature usage for new functionality development</li>
							<li>Providing technical support and fixing errors</li>
							<li>Personalizing user experience (only with consent)</li>
						</ul>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							We do not sell your data to third parties and do not use it for targeted advertising.
						</p>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Data Storage</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							Data is stored both locally on your device and on secure servers.
							Local data includes settings and preferences, while server data is used for analytics and service improvement.
						</p>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Third-Party Services</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							We use the following third-party services to improve the quality of our applications:
						</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li><strong>Google Analytics:</strong> for collecting anonymous app usage statistics</li>
							<li><strong>Google Firebase:</strong> for crash analysis and stability improvement</li>
							<li><strong>Google Crashlytics:</strong> for tracking and analyzing errors</li>
							<li><strong>Google Performance Monitoring:</strong> for monitoring app performance</li>
						</ul>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							These services collect only anonymous technical data and do not identify you personally.
						</p>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Security</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							We employ modern methods of data protection:
						</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li>Data encryption during transmission and storage</li>
							<li>Protection against unauthorized access</li>
							<li>Regular security updates</li>
							<li>Anonymization of personal data before analysis</li>
							<li>Compliance with industry security standards</li>
						</ul>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Our Policy Features</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							It's important to note the following aspects of our privacy policy:
						</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li>We do not track your geographic location</li>
							<li>We do not collect contacts from your address book</li>
							<li>We do not use data for credit scoring or evaluation</li>
							<li>We do not share data with government authorities (except as required by law)</li>
							<li>We do not create detailed user profiles for targeting</li>
						</ul>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">User Rights</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							You have the full right to:
						</p>
						<ul class="list-disc list-inside text-sm sm:text-base text-slate-600 dark:text-slate-300 space-y-1 sm:space-y-2 mb-4 sm:mb-6 font-light transition-colors">
							<li>Not provide any personal data</li>
							<li>Delete all application data at any time</li>
							<li>Inspect the source code of our applications</li>
							<li>Opt-out of any notifications or marketing messages</li>
						</ul>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Children</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							Our applications do not collect personal data and are not intended to collect information about children.
							We do not knowingly collect information from users under the age of 13.
						</p>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Changes to this Policy</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							We may update this privacy policy. All changes will be published in the application and on our website.
							The date of the last update is indicated at the beginning of the document.
						</p>

						<h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 mt-6 sm:mt-8 font-display transition-colors">Contact Us</h2>
						<p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 mb-4 sm:mb-6 leading-relaxed font-light transition-colors">
							If you have any questions about this privacy policy, you can contact us:
						</p>
						<div class="bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg p-3 sm:p-4 mb-4 sm:mb-6 transition-colors">
							<ul class="space-y-2 text-sm sm:text-base text-slate-600 dark:text-slate-300">
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-blue-500 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z"/>
									</svg>
									<span>GitHub: <a href="https://github.com/cybernattor" class="text-blue-600 dark:text-blue-400 hover:text-blue-500 dark:hover:text-blue-300 transition-colors">github.com/cybernattor</a></span>
								</li>
							</ul>
						</div>

						<div class="bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-500/20 rounded-lg p-3 sm:p-4 mt-6 sm:mt-8 transition-colors">
							<p class="text-blue-700 dark:text-blue-400 text-xs sm:text-sm">
								<strong>Important:</strong> We strive to balance app functionality with protection of your data.
							</p>
						</div>
					</div>
				</div>

				<!-- Navigation -->
				<div class="text-center">
					<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center">
						<Button href="/en" variant="outline" class="w-full sm:w-auto min-h-[44px]">
							<svg class="w-5 h-5 drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
								<path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"/>
							</svg>
							<span>{t('nav.home')}</span>
						</Button>
						<Button href="/en/about" variant="outline" class="w-full sm:w-auto min-h-[44px]">
							<svg class="w-5 h-5 drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
							</svg>
							<span>{t('nav.about')}</span>
						</Button>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
