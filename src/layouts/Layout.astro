---
export interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = "/og-image.png" } = Astro.props;
---

<!doctype html>
<html lang="ru" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Prevent scroll restoration -->
		<script>
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}
			// Ensure page starts at top
			window.addEventListener('beforeunload', function() {
				window.scrollTo(0, 0);
			});
		</script>

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="ru_RU" />

		<!-- Twitter Card Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Preconnect to external domains -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<!-- Global CSS -->
		<link rel="stylesheet" href="/styles/global.css" />
	</head>
	<body class="bg-slate-950 text-slate-100 font-[Inter:sans-serif] antialiased">
		<div class="min-h-screen flex flex-col">
			<!-- Header -->
			<header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-sm sticky top-0 z-50">
				<nav class="container mx-auto px-4 py-4">
					<div class="flex items-center justify-between">
						<div class="flex items-center space-x-2">
							<img src="/favicon.svg" alt="bit Tecnologies" class="w-8 h-8" />
							<span class="text-xl font-bold font-display bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">
								bit Tecnologies
							</span>
						</div>
						<div class="hidden md:flex space-x-6">
							<a href="/about" class="text-slate-300 hover:text-white transition-colors duration-200">О компании</a>
							<a href="#compatibility" class="text-slate-300 hover:text-white transition-colors duration-200">Совместимость</a>
							<a href="#download" class="text-slate-300 hover:text-white transition-colors duration-200">Скачать</a>
						</div>
						<!-- Mobile menu button -->
						<button class="md:hidden text-slate-300 hover:text-white transition-colors" onclick="toggleMobileMenu()">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
							</svg>
						</button>
					</div>
					<!-- Mobile menu -->
					<div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
						<div class="flex flex-col space-y-2">
							<a href="/about" class="text-slate-300 hover:text-white transition-colors duration-200 py-2">О компании</a>
							<a href="#compatibility" class="text-slate-300 hover:text-white transition-colors duration-200 py-2">Совместимость</a>
							<a href="#download" class="text-slate-300 hover:text-white transition-colors duration-200 py-2">Скачать</a>
						</div>
					</div>
				</nav>
			</header>

			<!-- Main Content -->
			<main class="flex-1">
				<slot />
			</main>

			<!-- Footer -->
			<footer class="border-t border-slate-800 bg-slate-900/50">
				<div class="container mx-auto px-4 py-8">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<div>
							<div class="flex items-center space-x-2 mb-4">
								<img src="/favicon.svg" alt="bit Tecnologies" class="w-6 h-6" />
								<h3 class="text-lg font-semibold font-display text-blue-400">bit Tecnologies</h3>
							</div>
							<p class="text-slate-400 text-sm font-light">
								Создаем нативные Android приложения с высокой производительностью и заботой о пользователях.
							</p>
						</div>
						<div>
							<h3 class="text-lg font-semibold mb-4 font-display text-blue-400">Продукты</h3>
							<ul class="space-y-2 text-sm">
								<li><a href="/bit-hub" class="text-slate-400 hover:text-white transition-colors">bit Hub</a></li>
								<li><a href="/bit-store" class="text-slate-400 hover:text-white transition-colors">bit Store</a></li>
							</ul>
						</div>
						<div>
							<h3 class="text-lg font-semibold mb-4 font-display text-blue-400">Контакты</h3>
							<div class="space-y-2 text-sm">
								<a href="https://github.com/cybernattor" class="flex items-center space-x-2 text-slate-400 hover:text-white transition-colors">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
									</svg>
									<span>GitHub</span>
								</a>
								<a href="/privacy" class="flex items-center space-x-2 text-slate-400 hover:text-white transition-colors">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.4,7 14.8,8.6 14.8,10V11H16V16H8V11H9.2V10C9.2,8.6 10.6,7 12,7M12,8.2C11.2,8.2 10.4,8.7 10.4,10V11H13.6V10C13.6,8.7 12.8,8.2 12,8.2Z"/>
									</svg>
									<span>Политика конфиденциальности</span>
								</a>
							</div>
						</div>
					</div>
					<div class="mt-8 pt-8 border-t border-slate-800 text-center text-sm text-slate-500">
						<p>&copy; 2026 bit Tecnologies. Все права защищены.</p>
					</div>
				</div>
			</footer>
		</div>

		<script>
			// Ensure page starts at top on load
			window.addEventListener('load', function() {
				window.scrollTo(0, 0);
				document.documentElement.scrollTop = 0;
				document.body.scrollTop = 0;
			});

			// Also check immediately
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', function() {
					window.scrollTo(0, 0);
				});
			} else {
				window.scrollTo(0, 0);
			}

			function toggleMobileMenu() {
				const menu = document.getElementById('mobile-menu');
				menu.classList.toggle('hidden');
			}

			// Close mobile menu when clicking on a link
			document.querySelectorAll('#mobile-menu a').forEach(link => {
				link.addEventListener('click', () => {
					document.getElementById('mobile-menu').classList.add('hidden');
				});
			});
		</script>
	</body>
</html>
