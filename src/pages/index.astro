	<!-- ============================== DOWNLOAD CTA ============================== -->
	<section id="download" class="py-20 md:py-32 relative overflow-hidden mesh-gradient bg-slate-50 dark:bg-slate-900/80 transition-colors duration-500">
		<div class="container mx-auto px-4">
			<div class="text-center max-w-3xl mx-auto reveal-scale">
				<div class="glass-effect gradient-border rounded-3xl p-12 md:p-16">
					<div class="mb-8">
						<Image src={favicon} alt="bit Hub" class="w-16 h-16 mx-auto mb-6 animate-bounce-subtle" />
					</div>
					<h2 class="text-3xl md:text-5xl font-bold mb-6 text-slate-900 dark:text-white font-display">
						Готовы попробовать?
					</h2>
					<p class="text-lg text-slate-600 dark:text-slate-300 mb-10 font-light max-w-xl mx-auto">
						Скачайте bit Hub прямо сейчас и ощутите разницу нативного подхода
					</p>
					<Button href={downloadUrl} variant="primary" download>
						<svg class="w-6 h-6 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
						</svg>
						<span>{t('hero.download_hub')}</span>
					</Button>
					<p class="text-sm text-slate-500 dark:text-slate-400 mt-6">
						Размер: ~100 МБ • Android 6+ • Установка из неизвестных источников
					</p>
				</div>
			</div>
		</div>

		<!-- Decorative blobs -->
		<div class="absolute -top-20 -left-20 w-72 h-72 bg-gradient-to-br from-blue-500/10 to-cyan-500/5 rounded-full blur-3xl pointer-events-none"></div>
		<div class="absolute -bottom-20 -right-20 w-80 h-80 bg-gradient-to-br from-emerald-500/10 to-teal-500/5 rounded-full blur-3xl pointer-events-none"></div>
	</section>
</Layout>
