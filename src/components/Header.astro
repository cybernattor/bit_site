---
// src/components/Header.astro
import ThemeToggle from './ThemeToggle.astro';
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, useTranslations, translatePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translate = translatePath(Astro.url);
---

<header class="border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md sticky top-0 z-50 transition-colors duration-300">
  <nav class="container mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <a href={translate('/')} class="flex flex-row items-center space-x-2">
        <img src="/favicon.svg" alt="bit Tecnologies" class="w-8 h-8" />
        <span class="text-xl font-bold font-display bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">
          bit Tecnologies
        </span>
      </a>
      <div class="hidden md:flex items-center space-x-6">
        <a href={translate('/about')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200">{t('nav.about')}</a>
        <a href={translate('/#compatibility')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200">{t('nav.compatibility')}</a>
        <a href={translate('/#download')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200">{t('nav.download')}</a>
        <LanguagePicker />
        <ThemeToggle />
      </div>
      <!-- Mobile menu buttons -->
      <div class="md:hidden flex items-center space-x-4">
        <LanguagePicker />
        <ThemeToggle />
        <button class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors" id="mobile-menu-btn" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-slate-100 dark:border-slate-800 transition-colors duration-300">
      <div class="flex flex-col space-y-2 pt-4">
        <a href={translate('/about')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 py-2">{t('nav.about')}</a>
        <a href={translate('/#compatibility')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 py-2">{t('nav.compatibility')}</a>
        <a href={translate('/#download')} class="text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors duration-200 py-2">{t('nav.download')}</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Script runs once on initial load and stays active across View Transitions
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if (btn && menu) {
      // Clean up old listeners (for ViewTransitions)
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });

      // Close mobile menu when clicking on a link
      document.querySelectorAll('#mobile-menu a').forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.add('hidden');
        });
      });
    }
  }

  // Setup on initial load
  setupMobileMenu();
  
  // Setup after each View Transition
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
