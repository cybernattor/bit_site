---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import favicon from '../../public/favicon.svg';
import { getLangFromUrl } from '../i18n/utils';

export interface Props {
	title: string;
	description: string;
	image?: string;
	schema?: Record<string, any>;
}

const { title, description, image = "/og-image.png", schema } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const defaultSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "bit Tecnologies",
	"url": "https://cybernattor.github.io", // Using github pages or custom domain as reference
	"logo": "https://cybernattor.github.io/favicon.svg",
	"sameAs": [
		"https://github.com/cybernattor"
	]
};

const jsonLd = schema || defaultSchema;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={favicon.src} />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- JSON-LD Schema -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Open Graph Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="ru_RU" />

		<!-- Twitter Card Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Preconnect to external domains -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
		
		<ClientRouter />

    <!-- Inline script to prevent FOUC with dark mode -->
    <script is:inline>
      function applyTheme() {
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark')
        }
      }

      // Initial load
      applyTheme();

      // Handle View Transitions
      document.addEventListener('astro:before-swap', (ev) => {
        const isDark = localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (isDark) {
          ev.newDocument.documentElement.classList.add('dark');
        } else {
          ev.newDocument.documentElement.classList.remove('dark');
        }
      });
      
      // Secondary check for robustness
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
	</head>
	<body class="bg-white dark:bg-slate-950 text-slate-800 dark:text-slate-100 font-[Inter,sans-serif] antialiased transition-colors duration-300">
		<div class="min-h-screen flex flex-col">
			<!-- Header Component -->
			<Header />

			<!-- Main Content -->
			<main class="flex-1">
				<slot />
			</main>

			<!-- Footer Component -->
			<Footer />
		</div>

		<!-- Scroll Reveal Observer -->
		<script>
			function setupRevealObserver() {
				const reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
				
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
						}
					});
				}, {
					threshold: 0.1,
					rootMargin: '0px 0px -50px 0px'
				});
				
				reveals.forEach(el => observer.observe(el));
			}

			// Cursor glow effect
			function setupCursorGlow() {
				document.querySelectorAll('.cursor-glow').forEach(el => {
					el.addEventListener('mousemove', (e) => {
						const rect = (el as HTMLElement).getBoundingClientRect();
						const x = e.clientX - rect.left;
						const y = e.clientY - rect.top;
						(el as HTMLElement).style.setProperty('--glow-x', `${x}px`);
						(el as HTMLElement).style.setProperty('--glow-y', `${y}px`);
						const before = (el as HTMLElement).querySelector('.glow-indicator') as HTMLElement;
						if (before) {
							before.style.left = `${x}px`;
							before.style.top = `${y}px`;
						}
					});
				});
			}

			// Setup on initial load
			setupRevealObserver();
			setupCursorGlow();
			
			// Re-setup after View Transitions
			document.addEventListener('astro:after-swap', () => {
				setupRevealObserver();
				setupCursorGlow();
			});
		</script>
	</body>
</html>
