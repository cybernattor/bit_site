---
import Layout from '../layouts/Layout.astro';

const title = 'bit Hub — Альтернатива F-Droid';
const description = 'bit Hub — нативный магазин приложений для Android с фокусом на приватность и производительность. Альтернатива F-Droid с минималистичным дизайном.';
const image = '/og-bit-hub.png';
---

<Layout title={title} description={description} image={image}>
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-950 to-slate-900">
		<div class="container mx-auto px-4 py-16 md:py-24">
			<div class="max-w-4xl mx-auto">
				<!-- App Header -->
				<div class="text-center mb-12">
					<img src="/favicon.svg" alt="bit Hub" class="w-24 h-24 mx-auto mb-6" />
					<h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent font-display">
						bit Hub
					</h1>
					<p class="text-lg md:text-xl text-slate-300 mb-4 font-light">
						Нативный магазин приложений с фокусом на приватность
					</p>
					<div class="flex items-center justify-center space-x-4 mb-6">
						<span class="inline-block px-3 py-1 bg-emerald-500/20 text-emerald-400 text-sm rounded-full">Beta</span>
						<span class="text-slate-400">•</span>
						<span class="text-slate-400">Android 10+</span>
						<span class="text-slate-400">•</span>
						<span class="text-slate-400">2.4 МБ</span>
					</div>
					<a
						href="#download"
						class="inline-flex items-center space-x-2 px-8 py-4 bg-gradient-to-r from-blue-500 to-emerald-500 text-white font-semibold rounded-lg hover:from-blue-600 hover:to-emerald-600 transition-all duration-200 text-lg shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transform hover:scale-105"
						download
					>
						<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
						</svg>
						<span>Скачать bit Hub</span>
					</a>
				</div>

				<!-- Features -->
				<div class="glass-effect rounded-xl p-8 mb-8">
					<h2 class="text-2xl font-bold mb-6 text-white text-center font-display">Ключевые особенности</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="flex items-start space-x-3">
							<svg class="w-6 h-6 text-emerald-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
								<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
							</svg>
							<div>
								<h3 class="text-lg font-semibold text-white mb-1 font-display">Нативная производительность</h3>
								<p class="text-slate-400 text-sm font-light">Написан на Kotlin с нативным UI, работает быстро даже на старых устройствах</p>
							</div>
						</div>
						<div class="flex items-start space-x-3">
							<svg class="w-6 h-6 text-emerald-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
								<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
							</svg>
							<div>
								<h3 class="text-lg font-semibold text-white mb-1 font-display">Без telemetry</h3>
								<p class="text-slate-400 text-sm font-light">Никакой аналитики, телеметрии или отслеживания действий пользователей</p>
							</div>
						</div>
						<div class="flex items-start space-x-3">
							<svg class="w-6 h-6 text-emerald-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
								<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
							</svg>
							<div>
								<h3 class="text-lg font-semibold text-white mb-1 font-display">Автоматические обновления</h3>
								<p class="text-slate-400 text-sm font-light">Фоновая проверка и установка обновлений без участия пользователя</p>
							</div>
						</div>
						<div class="flex items-start space-x-3">
							<svg class="w-6 h-6 text-emerald-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
								<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
							</svg>
							<div>
								<h3 class="text-lg font-semibold text-white mb-1 font-display">Репозитории F-Droid</h3>
								<p class="text-slate-400 text-sm font-light">Полная совместимость с существующими репозиториями F-Droid</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Screenshots -->
				<div class="glass-effect rounded-xl p-8 mb-8">
					<h2 class="text-2xl font-bold mb-6 text-white text-center font-display">Интерфейс приложения</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
						<div class="bg-slate-800 rounded-lg p-4 text-center">
							<div class="w-full h-48 bg-slate-700 rounded-lg mb-2 flex items-center justify-center">
								<svg class="w-16 h-16 text-slate-500" fill="currentColor" viewBox="0 0 24 24">
									<path d="M4,6H20V18H4V6M6,8V16H18V8H6M8,10H16V12H8V10M8,14H13V16H8V14Z"/>
								</svg>
							</div>
							<p class="text-slate-400 text-sm">Главный экран</p>
						</div>
						<div class="bg-slate-800 rounded-lg p-4 text-center">
							<div class="w-full h-48 bg-slate-700 rounded-lg mb-2 flex items-center justify-center">
								<svg class="w-16 h-16 text-slate-500" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
								</svg>
							</div>
							<p class="text-slate-400 text-sm">Настройки</p>
						</div>
						<div class="bg-slate-800 rounded-lg p-4 text-center">
							<div class="w-full h-48 bg-slate-700 rounded-lg mb-2 flex items-center justify-center">
								<svg class="w-16 h-16 text-slate-500" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
								</svg>
							</div>
							<p class="text-slate-400 text-sm">Обновления</p>
						</div>
					</div>
				</div>

				<!-- Technical Details -->
				<div class="glass-effect rounded-xl p-8 mb-8">
					<h2 class="text-2xl font-bold mb-6 text-white text-center font-display">Технические детали</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<h3 class="text-lg font-semibold text-white mb-3 font-display">Системные требования</h3>
							<ul class="space-y-2 text-slate-300">
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
									</svg>
									<span>Android 10 (API 29) и выше</span>
								</li>
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
									</svg>
									<span>ARMv7, ARM64, x86, x86_64</span>
								</li>
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
									</svg>
									<span>2 ГБ ОЗУ (рекомендуется)</span>
								</li>
							</ul>
						</div>
						<div>
							<h3 class="text-lg font-semibold text-white mb-3 font-display">Технологический стек</h3>
							<ul class="space-y-2 text-slate-300">
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
									</svg>
									<span>Kotlin + Coroutines</span>
								</li>
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
									</svg>
									<span>Jetpack Compose</span>
								</li>
								<li class="flex items-center space-x-2">
									<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
									</svg>
									<span>Room Database</span>
								</li>
							</ul>
						</div>
					</div>
				</div>

				<!-- Open Source -->
				<div class="glass-effect rounded-xl p-8 mb-8">
					<div class="text-center">
						<svg class="w-16 h-16 text-slate-400 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z"/>
						</svg>
						<h3 class="text-xl font-semibold text-white mb-2 font-display">Открытый исходный код</h3>
						<p class="text-slate-400 mb-4 max-w-2xl mx-auto font-light">
							bit Hub распространяется под лицензией GPLv3. Исходный код доступен на GitHub для изучения и внесения вклада.
						</p>
						<a href="https://github.com/cybernattor/bit-hub" class="inline-flex items-center space-x-2 text-blue-400 hover:text-blue-300 transition-colors">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z"/>
							</svg>
							<span>Посмотреть на GitHub</span>
						</a>
					</div>
				</div>

				<!-- Navigation -->
				<div class="text-center">
					<a href="/" class="inline-flex items-center space-x-2 px-6 py-3 border border-slate-600 text-slate-300 font-semibold rounded-lg hover:bg-slate-800 hover:text-white transition-all duration-200 mr-4">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"/>
						</svg>
						<span>Вернуться на главную</span>
					</a>
					<a href="/privacy" class="inline-flex items-center space-x-2 px-6 py-3 border border-slate-600 text-slate-300 font-semibold rounded-lg hover:bg-slate-800 hover:text-white transition-all duration-200">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.4,7 14.8,8.6 14.8,10V11H16V16H8V11H9.2V10C9.2,8.6 10.6,7 12,7M12,8.2C11.2,8.2 10.4,8.7 10.4,10V11H13.6V10C13.6,8.7 12.8,8.2 12,8.2Z"/>
						</svg>
						<span>Политика конфиденциальности</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
