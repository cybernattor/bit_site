---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import FeatureCard from '../components/FeatureCard.astro';

const title = 'bit Delta — Шагомер и отслеживание здоровья';
const description = 'bit Delta — шагомер, отслеживание активности и здоровья.';
const image = '/og-bit-hub.png';

const schema = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	"name": "bit Delta",
	"operatingSystem": "Android",
	"applicationCategory": "HealthApplication",
	"offers": {
		"@type": "Offer",
		"price": "0",
		"priceCurrency": "USD"
	}
};
---

<Layout title={title} description={description} schema={schema} image={image}>
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300">
		<div class="container mx-auto px-4 py-16 md:py-24">
			<div class="max-w-4xl mx-auto z-10 relative">
				<!-- App Header -->
				<div class="text-center mb-12">
					<img src="/favicon.svg" alt="bit Delta" class="w-24 h-24 mx-auto mb-6 drop-shadow-md" />
					<h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-purple-600 to-pink-500 dark:from-purple-500 dark:to-pink-500 bg-clip-text text-transparent font-display drop-shadow-sm">
						bit Delta
					</h1>
					<p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 mb-4 font-light transition-colors">
						Шагомер, отслеживание активности и здоровья
					</p>
					<div class="flex items-center justify-center space-x-4 mb-6">
						<span class="inline-block px-3 py-1 bg-blue-100 dark:bg-blue-500/20 text-blue-700 dark:text-blue-400 text-sm rounded-full transition-colors">In Development</span>
						<span class="text-slate-400 dark:text-slate-500 transition-colors">•</span>
						<span class="text-slate-600 dark:text-slate-400 transition-colors">Android 12+</span>
						<span class="text-slate-400 dark:text-slate-500 transition-colors">•</span>
						<span class="text-slate-600 dark:text-slate-400 transition-colors">~5 МБ</span>
					</div>
					<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
						<button disabled class="inline-flex items-center space-x-2 px-8 py-4 bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400 font-semibold rounded-lg cursor-not-allowed opacity-70 transition-colors">
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
							</svg>
							<span>Скоро будет доступно</span>
						</button>
            <Button href="#notify" variant="outline" class="border-purple-500 text-purple-600 hover:bg-purple-50 dark:text-purple-400 dark:hover:bg-purple-500/10">
							<svg class="w-6 h-6 drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
								<path d="M18,16V12A6,6 0 0,0 12,6A6,6 0 0,0 6,12V16H4V18H20V16H18M12,22A2,2 0 0,0 14,20H10A2,2 0 0,0 12,22Z"/>
							</svg>
							<span>Уведомить о выходе</span>
            </Button>
					</div>
				</div>

				<!-- Features -->
				<div class="glass-effect rounded-xl p-8 mb-8 bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 backdrop-blur-md shadow-xl transition-colors">
					<h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-white text-center font-display transition-colors">Возможности приложения</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <FeatureCard 
              title="Мониторинг активности" 
              iconColor="text-purple-600 dark:text-purple-400"
              description="Отслеживание пройденных шагов, дистанции и потраченных калорий в течение дня"
            >
              <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
              </svg>
            </FeatureCard>
            <FeatureCard 
              title="Анализ здоровья" 
              iconColor="text-purple-600 dark:text-purple-400"
              description="Наглядные графики и статистика для контроля за вашим прогрессом"
            >
              <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
              </svg>
            </FeatureCard>
            <FeatureCard 
              title="Нативная производительность" 
              iconColor="text-purple-600 dark:text-purple-400"
              description="Глубокая интеграция с Android Health Connect и акселерометром устройства"
            >
              <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
              </svg>
            </FeatureCard>
            <FeatureCard 
              title="Без рекламы и трекеров" 
              iconColor="text-purple-600 dark:text-purple-400"
              description="Чистый интерфейс без навязчивой рекламы и скрытой телеметрии"
            >
              <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
              </svg>
            </FeatureCard>
					</div>
				</div>

				<!-- Categories - customized for bit Delta as modules -->
				<div class="glass-effect rounded-xl p-8 mb-8 bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 backdrop-blur-md shadow-xl transition-colors">
					<h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-white text-center font-display transition-colors">Модули приложения</h2>
					<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
						<div class="bg-slate-100 dark:bg-slate-800/50 rounded-lg p-4 text-center hover:bg-slate-200 dark:hover:bg-slate-700/50 transition-colors border border-slate-200 dark:border-slate-700">
							<svg class="w-8 h-8 text-purple-600 dark:text-purple-400 mx-auto mb-2 transition-colors" fill="currentColor" viewBox="0 0 24 24">
								<path d="M13.5,5.5C11,5.5 9,7.5 9,10C9,12.5 11,14.5 13.5,14.5C16,14.5 18,12.5 18,10C18,7.5 16,5.5 13.5,5.5M10.12,4.83C10.5,3.69 11.55,3 12.63,3C14.19,3 15.63,3.95 16.03,5.43C16.89,8.5 15.03,11.59 11.96,12.44C8.89,13.29 5.8,11.43 4.93,8.37C4.69,7.53 4.74,6.66 5.06,5.88L2.56,3.38L3.97,1.97L6.47,4.47L7.88,3.06L9.3,4.47L10.12,4.83M12.63,5C12,5 11.4,5.4 11.2,6C10.7,7.8 11.7,9.6 13.5,10.1C15.3,10.6 17.1,9.6 17.6,7.8C18.1,6 17.1,4.2 15.3,3.7C14.7,3.5 14,3.7 13.5,4L12.63,5Z"/>
							</svg>
							<p class="text-slate-700 dark:text-slate-300 text-sm font-light transition-colors">Шагомер</p>
						</div>
						<div class="bg-slate-100 dark:bg-slate-800/50 rounded-lg p-4 text-center hover:bg-slate-200 dark:hover:bg-slate-700/50 transition-colors border border-slate-200 dark:border-slate-700">
							<svg class="w-8 h-8 text-pink-600 dark:text-pink-400 mx-auto mb-2 transition-colors" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
							</svg>
							<p class="text-slate-700 dark:text-slate-300 text-sm font-light transition-colors">Аналитика</p>
						</div>
						<div class="bg-slate-100 dark:bg-slate-800/50 rounded-lg p-4 text-center hover:bg-slate-200 dark:hover:bg-slate-700/50 transition-colors border border-slate-200 dark:border-slate-700">
							<svg class="w-8 h-8 text-blue-600 dark:text-blue-400 mx-auto mb-2 transition-colors" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z"/>
							</svg>
							<p class="text-slate-700 dark:text-slate-300 text-sm font-light transition-colors">Сон</p>
						</div>
						<div class="bg-slate-100 dark:bg-slate-800/50 rounded-lg p-4 text-center hover:bg-slate-200 dark:hover:bg-slate-700/50 transition-colors border border-slate-200 dark:border-slate-700">
							<svg class="w-8 h-8 text-emerald-600 dark:text-emerald-400 mx-auto mb-2 transition-colors" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12.1,18.55L12,18.65L11.89,18.55C7.14,14.24 4,11.39 4,8.5C4,6.5 5.5,5 7.5,5C9.04,5 10.54,6 11.07,7.36H12.93C13.46,6 14.96,5 16.5,5C18.5,5 20,6.5 20,8.5C20,11.39 16.86,14.24 12.1,18.55M16.5,3C14.76,3 13.09,3.81 12,5.08C10.91,3.81 9.24,3 7.5,3C4.42,3 2,5.41 2,8.5C2,12.27 5.4,15.36 10.55,20.03L12,21.35L13.45,20.03C18.6,15.36 22,12.27 22,8.5C22,5.41 19.58,3 16.5,3Z"/>
							</svg>
							<p class="text-slate-700 dark:text-slate-300 text-sm font-light transition-colors">Здоровье</p>
						</div>
					</div>
				</div>

				<!-- Roadmap -->
				<div class="glass-effect rounded-xl p-8 mb-8 bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 backdrop-blur-md shadow-xl transition-colors">
					<h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-white text-center font-display transition-colors">Дорожная карта разработки</h2>
					<div class="space-y-4">
						<div class="flex items-start space-x-3">
							<div class="w-8 h-8 bg-green-100 dark:bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0 transition-colors">
								<svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
							</div>
							<div>
								<h3 class="text-lg font-semibold text-slate-900 dark:text-white font-display transition-colors">Q1 2026 - Базовый функционал</h3>
								<p class="text-slate-600 dark:text-slate-400 text-sm font-light transition-colors">Шагомер, базовая статистика, профиль пользователя</p>
							</div>
						</div>
						<div class="flex items-start space-x-3">
							<div class="w-8 h-8 bg-blue-100 dark:bg-blue-500/20 rounded-full flex items-center justify-center flex-shrink-0 transition-colors">
								<div class="w-2 h-2 bg-blue-500 dark:bg-blue-400 rounded-full transition-colors"></div>
							</div>
							<div>
								<h3 class="text-lg font-semibold text-slate-900 dark:text-white font-display transition-colors">Q2 2026 - Интеграция датчиков</h3>
								<p class="text-slate-600 dark:text-slate-400 text-sm font-light transition-colors">Анализ сна, пульсометр, Health Connect</p>
							</div>
						</div>
						<div class="flex items-start space-x-3">
							<div class="w-8 h-8 bg-slate-200 dark:bg-slate-600/20 rounded-full flex items-center justify-center flex-shrink-0 transition-colors">
								<div class="w-2 h-2 bg-slate-400 rounded-full transition-colors"></div>
							</div>
							<div>
								<h3 class="text-lg font-semibold text-slate-900 dark:text-white font-display transition-colors">Q3 2026 - Глубокая аналитика</h3>
								<p class="text-slate-600 dark:text-slate-400 text-sm font-light transition-colors">Отчеты, достижения, цели и рекомендации</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Notify Form -->
				<div id="notify" class="glass-effect rounded-xl p-8 mb-8 bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 backdrop-blur-md shadow-xl transition-colors">
					<h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-white text-center font-display transition-colors">Уведомить о выходе</h2>
					<p class="text-slate-600 dark:text-slate-400 text-center mb-6 font-light transition-colors">
						Оставьте ваш email, и мы сообщим о запуске приложения
					</p>
					<div class="max-w-md mx-auto">
						<div class="flex flex-col sm:flex-row gap-3">
							<input
								type="email"
								placeholder="your@email.com"
								class="flex-1 px-4 py-3 bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-lg text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors shadow-sm"
							>
							<button class="px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-500 dark:from-purple-500 dark:to-pink-500 text-white font-semibold rounded-lg hover:from-purple-700 hover:to-pink-600 dark:hover:from-purple-600 dark:hover:to-pink-600 transition-all duration-200 shadow-md">
								Подписаться
							</button>
						</div>
						<p class="text-slate-500 text-xs text-center mt-3 font-light">
							Никакого спама. Только уведомления о запуске.
						</p>
					</div>
				</div>

				<!-- Navigation -->
				<div class="text-center">
          <Button href="/" variant="outline" class="mr-4">
						<svg class="w-5 h-5 drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
							<path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"/>
						</svg>
						<span>Вернуться на главную</span>
          </Button>
          <Button href="/bit-hub" variant="outline">
						<svg class="w-5 h-5 drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
						</svg>
						<span>bit Hub</span>
          </Button>
				</div>
			</div>
		</div>
	</section>
</Layout>
