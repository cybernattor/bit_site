---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import FeatureCard from '../components/FeatureCard.astro';

const title = 'bit Launcher — Быстрый приватный Android-лаунчер';
const description = 'bit Launcher — быстрый и приватный Android-лаунчер с чистым интерфейсом и нативной скоростью.';

const schema = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	"name": "bit Launcher",
	"operatingSystem": "Android",
	"applicationCategory": "UtilitiesApplication",
	"offers": {
		"@type": "Offer",
		"price": "0",
		"priceCurrency": "USD"
	}
};
---

<Layout title={title} description={description} schema={schema}>
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300">
		<div class="container mx-auto px-4 py-16 md:py-24">
			<div class="max-w-4xl mx-auto z-10 relative">
				<div class="text-center mb-12">
					<div class="w-24 h-24 bg-gradient-to-br from-sky-500 to-emerald-500 rounded-lg flex items-center justify-center mx-auto mb-6 drop-shadow-md">
						<svg class="w-12 h-12 text-white drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12,2A5,5 0 0,0 7,7C7,8.76 7.91,10.31 9.28,11.2C8.47,12.73 8,14.69 8,17H10C10,14.83 10.45,13.04 11.2,11.79C11.46,11.92 11.73,12 12,12C12.27,12 12.54,11.92 12.8,11.79C13.55,13.04 14,14.83 14,17H16C16,14.69 15.53,12.73 14.72,11.2C16.09,10.31 17,8.76 17,7A5,5 0 0,0 12,2M12,4A3,3 0 0,1 15,7A3,3 0 0,1 12,10A3,3 0 0,1 9,7A3,3 0 0,1 12,4M6,18L4,22H8L10,18H6M14,18L16,22H20L18,18H14Z"/>
						</svg>
					</div>
					<h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-sky-600 to-emerald-500 dark:from-sky-400 dark:to-emerald-400 bg-clip-text text-transparent font-display drop-shadow-sm">
						bit Launcher
					</h1>
					<p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 mb-4 font-light transition-colors">
						Быстрый и приватный Android-лаунчер с чистым интерфейсом
					</p>
					<div class="flex items-center justify-center space-x-4 mb-6 transition-colors">
						<span class="inline-block px-3 py-1 bg-blue-100 dark:bg-blue-500/20 text-blue-700 dark:text-blue-400 text-sm rounded-full">В разработке</span>
						<span class="text-slate-400 dark:text-slate-500">•</span>
						<span class="text-slate-600 dark:text-slate-400">Android 10+</span>
						<span class="text-slate-400 dark:text-slate-500">•</span>
						<span class="text-slate-600 dark:text-slate-400">TBA</span>
					</div>
					<div class="inline-flex items-center space-x-2 px-8 py-4 border border-slate-300 dark:border-slate-600 text-slate-500 dark:text-slate-400 font-semibold rounded-lg cursor-not-allowed transition-colors bg-white/50 dark:bg-transparent backdrop-blur-sm">
						<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
							<path d="M18,16V12A6,6 0 0,0 12,6A6,6 0 0,0 6,12V16H4V18H20V16H18M12,22A2,2 0 0,0 14,20H10A2,2 0 0,0 12,22Z"/>
						</svg>
						<span>Скоро будет доступно</span>
					</div>
				</div>

				<div class="glass-effect rounded-xl p-8 mb-8 bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 backdrop-blur-md shadow-xl transition-colors">
					<h2 class="text-2xl font-bold mb-6 text-slate-900 dark:text-white text-center font-display transition-colors">Ключевые идеи</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<FeatureCard title="Чистый домашний экран" iconColor="text-sky-600 dark:text-sky-400" description="Фокус на быстрый запуск приложений без визуального шума и рекламных блоков.">
							<svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/></svg>
						</FeatureCard>
						<FeatureCard title="Быстрый поиск" iconColor="text-sky-600 dark:text-sky-400" description="Мгновенный доступ к приложениям, действиям и настройкам устройства.">
							<svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L20.71,20L19.29,21.41L13.03,15.15C11.89,16.03 10.43,16.5 9,16.5A6.5,6.5 0 0,1 2.5,10A6.5,6.5 0 0,1 9.5,3Z"/></svg>
						</FeatureCard>
						<FeatureCard title="Приватность" iconColor="text-sky-600 dark:text-sky-400" description="Без телеметрии, сторонней аналитики и рекомендаций, построенных на отслеживании.">
							<svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"/></svg>
						</FeatureCard>
						<FeatureCard title="Нативная скорость" iconColor="text-sky-600 dark:text-sky-400" description="Легкая Android-реализация с акцентом на плавность и низкий расход ресурсов.">
							<svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24"><path d="M13,2.03V2.05L13,4.05C17.39,4.59 20.5,8.58 19.96,12.97C19.5,16.61 16.64,19.5 13,19.93V21.93C18.5,21.38 22.5,16.5 21.95,11C21.5,6.25 17.73,2.5 13,2.03M11,2.06C9.05,2.25 7.19,3 5.67,4.26L7.1,5.74C8.22,4.84 9.57,4.26 11,4.06V2.06Z"/></svg>
						</FeatureCard>
					</div>
				</div>

				<div class="text-center">
					<Button href="/#apps" variant="outline" class="mr-4">
						<span>Вернуться к продуктам</span>
					</Button>
					<Button href="/bit-hub" variant="outline">
						<span>bit Hub</span>
					</Button>
				</div>
			</div>
		</div>
	</section>
</Layout>
