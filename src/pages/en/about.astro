---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const title = 'About Us — bit Tecnologies';
const description = 'Learn more about bit Tecnologies. Our mission is to create high-quality, native and private Android applications.';
const image = '/og-bit-hub.png';

const schema = {
	"@context": "https://schema.org",
	"@type": "AboutPage",
	"name": title,
	"description": description
};
---

<Layout title={title} description={description} schema={schema} image={image}>
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-950 to-slate-900">
		<div class="container mx-auto px-4 py-16 md:py-24">
			<div class="max-w-4xl mx-auto z-10 relative">
				<div class="text-center mb-12">
					<img src="/favicon.svg" alt="bit Tecnologies" class="w-20 h-20 mx-auto mb-6 drop-shadow-lg" style="view-transition-name: hero-logo;" />
					<h1 class="text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent font-display drop-shadow-sm">
						About bit Tecnologies
					</h1>
					<p class="text-lg md:text-xl text-slate-300 leading-relaxed font-light">
						Creating native Android applications with high performance and care for users
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <FeatureCard 
            title="Our Mission" 
            iconColor="text-blue-500"
            description="Develop lightweight, fast, and secure Android apps without unnecessary dependencies and telemetry. We believe in users' right to privacy and control over their data."
          >
            <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
            </svg>
          </FeatureCard>

          <FeatureCard title="Our Values" iconColor="text-emerald-500">
            <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9,11H7V13H9V11M13,11H11V13H13V11M17,11H15V13H17V11M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V6A2,2 0 0,0 19,4M19,20H5V9H19V20Z"/>
            </svg>
						<ul class="space-y-2 text-slate-300">
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Native performance</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Privacy by default</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Open source software</span>
							</li>
						</ul>
          </FeatureCard>
				</div>

				<div class="glass-effect rounded-xl p-8 mb-12">
					<h2 class="text-2xl font-bold mb-6 text-white text-center font-display">Technology Stack</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <FeatureCard 
              title="Kotlin & Java"
              description="Native development on official Android languages"
              iconColor="text-white"
              iconBgColor="from-green-500 to-emerald-500"
            >
              <svg slot="icon" class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
              </svg>
            </FeatureCard>
            
            <FeatureCard 
              title="Jetpack Compose"
              description="Modern UI toolkit for declarative interfaces"
              iconColor="text-white"
              iconBgColor="from-blue-500 to-cyan-500"
            >
              <svg slot="icon" class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
              </svg>
            </FeatureCard>

            <FeatureCard 
              title="Material Design 3"
              description="Modern design with dynamic theming"
              iconColor="text-white"
              iconBgColor="from-purple-500 to-pink-500"
            >
              <svg slot="icon" class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
              </svg>
            </FeatureCard>
					</div>
				</div>

				<div class="text-center">
          <Button href="/en" variant="primary">
						<svg class="w-5 h-5 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
							<path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"/>
						</svg>
						<span>{t('nav.home')}</span>
          </Button>
				</div>
			</div>
		</div>
	</section>
</Layout>
