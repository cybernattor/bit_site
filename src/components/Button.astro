---
// src/components/Button.astro
export interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
  download?: boolean;
}

const { href, variant = 'primary', class: className = '', download = false } = Astro.props;

const baseStyles = "inline-flex items-center justify-center space-x-2 px-4 sm:px-6 lg:px-8 py-2.5 sm:py-3 font-semibold rounded-lg transition-all duration-200 min-h-[44px] touch-manipulation";

const variants = {
  primary: "bg-gradient-to-r from-blue-600 to-emerald-600 dark:from-blue-500 dark:to-emerald-500 text-white hover:from-blue-700 dark:hover:from-blue-600 hover:to-emerald-700 dark:hover:to-emerald-600 shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transform hover:scale-105 active:scale-95",
  secondary: "bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white hover:bg-slate-300 dark:hover:bg-slate-700 active:scale-95",
  outline: "border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white hover:border-slate-400 dark:hover:border-slate-500 active:scale-95"
};
---

<a
  href={href}
  class={`${baseStyles} ${variants[variant]} ${className}`}
  download={download ? '' : undefined}
>
  <slot />
</a>
