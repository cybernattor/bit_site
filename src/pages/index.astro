---
import Layout from '../layouts/Layout.astro';
import AppCard from '../components/AppCard.astro';
import Button from '../components/Button.astro';
import FeatureCard from '../components/FeatureCard.astro';

const title = 'bit Tecnologies — Экосистема удобных приложений';
const description = 'bit Tecnologies разрабатывает нативные, быстрые и приватные приложения для Android. Никакой телеметрии и рекламы.';

const schema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "bit Tecnologies",
	"url": "https://cybernattor.github.io",
	"description": description
};
---

<Layout title={title} description={description} schema={schema}>

  <!-- Redirect snippet for new un-preferenced english users -->
  <script is:inline>
    // Run immediately before page paints
    (function () {
      const storedLang = localStorage.getItem('user-lang');
      
      // If no stored pref and they are explicitly on root (Russian)
      if (!storedLang && window.location.pathname === '/') {
        // Check browser language
        const browserLang = navigator.language || navigator.userLanguage;
        
        // If English, redirect to /en/
        if (browserLang.toLowerCase().startsWith('en')) {
          localStorage.setItem('user-lang', 'en');
          window.location.replace('/en/');
        } else {
          localStorage.setItem('user-lang', 'ru');
        }
      }
    })();
  </script>

	<!-- Hero Section -->
	<section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300">
		<div class="container mx-auto px-4 py-16 md:py-24">
			<div class="text-center max-w-4xl mx-auto z-10 relative">
				<div class="mb-6" style="view-transition-name: hero-logo;">
					<img src="/favicon.svg" alt="bit Tecnologies" class="w-20 h-20 mx-auto mb-6 drop-shadow-lg" />
				</div>
				<h1 class="text-4xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-emerald-600 dark:from-blue-500 dark:to-emerald-500 bg-clip-text text-transparent animate-pulse font-display drop-shadow-sm">
					bit Tecnologies
				</h1>
				<p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 mb-8 max-w-2xl mx-auto leading-relaxed font-light">
					Создаем нативные Android приложения с высокой производительностью и заботой о пользователях.
					Минимум зависимостей, максимум оптимизации.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
					<Button href="#download" variant="primary" download>
						<svg class="w-5 h-5 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
						</svg>
						<span>Скачать bit Hub (APK)</span>
					</Button>
					<Button href="/about" variant="outline">
						О компании
					</Button>
				</div>
			</div>
		</div>
		<!-- Decorative gradient -->
		<div class="absolute inset-0 bg-gradient-to-t from-blue-500/5 to-transparent pointer-events-none"></div>
		<!-- Animated background elements -->
		<div class="absolute top-20 left-10 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl animate-pulse"></div>
		<div class="absolute bottom-20 right-10 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
	</section>

	<!-- App Showcase -->
	<section id="apps" class="py-16 md:py-24 bg-slate-50/50 dark:bg-slate-900/50 transition-colors duration-300">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900 dark:text-white font-display">Наши приложения</h2>
				<p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-light">
					Нативные Android приложения, созданные с акцентом на производительность и пользовательский опыт
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
				<!-- bit Hub Card -->
        <AppCard 
          href="/bit-hub"
          name="bit Hub"
          status={{ label: "Beta", color: "emerald" }}
          description="Альтернатива F-Droid с нативной разработкой. Магазин приложений с фокусом на приватность и производительность."
          requirements="Android 10+"
          size="2.4 МБ"
          iconImage="/favicon.svg"
        />

				<!-- bit Delta Card -->
        <AppCard 
          href="/bit-delta"
          name="bit Delta"
          status={{ label: "In Development", color: "blue" }}
          description="Шагомер, отслеживание активности и здоровья."
          requirements="Android 12+"
          size="~5 МБ"
          iconBgColor="from-purple-500 to-pink-500"
        >
          <svg slot="icon" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
          </svg>
        </AppCard>

				<!-- bit Record Card -->
        <AppCard 
          href="/bit-record"
          name="bit Record"
          status={{ label: "Planning", color: "yellow" }}
          description="Простой, минималистичный сервис для записи экрана."
          requirements="Android 11+"
          size="~3 МБ"
          iconBgColor="from-red-500 to-orange-500"
        >
          <svg slot="icon" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.4,7 14.8,8.6 14.8,10V11H16V16H8V11H9.2V10C9.2,8.6 10.6,7 12,7M12,8.2C11.2,8.2 10.4,8.7 10.4,10V11H13.6V10C13.6,8.7 12.8,8.2 12,8.2Z"/>
          </svg>
        </AppCard>
			</div>
		</div>
	</section>

	<!-- Android Compatibility -->
	<section id="compatibility" class="py-16 md:py-24 bg-white dark:bg-slate-950 transition-colors duration-300">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900 dark:text-white font-display">Совместимость</h2>
					<p class="text-slate-600 dark:text-slate-400 font-light">
						Наши приложения оптимизированы для работы на широком спектре Android устройств
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <FeatureCard title="Минимальные требования" iconColor="text-green-500">
            <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9,11H7V13H9V11M13,11H11V13H13V11M17,11H15V13H17V11M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V6A2,2 0 0,0 19,4M19,20H5V9H19V20Z"/>
            </svg>
						<ul class="space-y-2 text-slate-300">
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Android 10 (API 29) и выше</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>2 ГБ ОЗУ (рекомендуется)</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>ARMv7 или ARM64 архитектура</span>
							</li>
						</ul>
          </FeatureCard>

          <FeatureCard title="Тестирование" iconColor="text-blue-500">
            <svg slot="icon" class="w-full h-full" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/>
            </svg>
						<ul class="space-y-2 text-slate-300">
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Протестировано на Android 16</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Поддержка Mi A2 Lite и других</span>
							</li>
							<li class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
								</svg>
								<span>Оптимизация для старых устройств</span>
							</li>
						</ul>
          </FeatureCard>
				</div>
			</div>
		</div>
	</section>

	<!-- Download CTA -->
	<section id="download" class="py-16 md:py-24 bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-950 dark:to-slate-900 transition-colors duration-300 border-t border-slate-200 dark:border-slate-800">
		<div class="container mx-auto px-4">
			<div class="text-center max-w-3xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-bold mb-6 text-slate-900 dark:text-white font-display">Готовы попробовать?</h2>
				<p class="text-lg text-slate-600 dark:text-slate-300 mb-8 font-light">
					Скачайте bit Hub прямо сейчас и оцените преимущества нативных Android приложений
				</p>
        <Button href="#download" variant="primary" download>
					<svg class="w-6 h-6 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
						<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14l-4-4h3V9h2v4h3l-4 4z"/>
					</svg>
					<span>Скачать bit Hub</span>
        </Button>
				<p class="text-sm text-slate-500 mt-4">
					Размер файла: ~2.4 МБ • Требуется Android 10+ • Установка из неизвестных источников
				</p>
			</div>
		</div>
	</section>
</Layout>
