---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import favicon from '../../public/favicon.svg';
import { getLangFromUrl } from '../i18n/utils';

export interface Props {
	title: string;
	description: string;
	image?: string;
	schema?: Record<string, any>;
}

const { title, description, image = "/og-image.png", schema } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://cybernattor.github.io');

// Build alternate language URLs
const currentPath = Astro.url.pathname;
const ruURL = new URL(currentPath.replace(/^\/en\//, '/').replace(/^\/en$/, '/'), Astro.site || 'https://cybernattor.github.io');
const enURL = new URL(currentPath.startsWith('/en') ? currentPath : `/en${currentPath}`, Astro.site || 'https://cybernattor.github.io');

const defaultSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "bit Tecnologies",
	"url": "https://cybernattor.github.io", // Using github pages or custom domain as reference
	"logo": "https://cybernattor.github.io/favicon.svg",
	"sameAs": [
		"https://github.com/cybernattor"
	]
};

const jsonLd = schema || defaultSchema;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={favicon.src} />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- JSON-LD Schema -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Open Graph Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={lang === 'en' ? 'en_US' : 'ru_RU'} />
		<meta property="og:url" content={canonicalURL.href} />

		<!-- Canonical & Hreflang -->
		<link rel="canonical" href={canonicalURL.href} />
		<link rel="alternate" hreflang="ru" href={ruURL.href} />
		<link rel="alternate" hreflang="en" href={enURL.href} />
		<link rel="alternate" hreflang="x-default" href={ruURL.href} />

		<!-- Twitter Card Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Preconnect to external domains -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<ClientRouter />

    <!-- Inline script to prevent FOUC with dark mode -->
    <script is:inline>
      function applyTheme() {
        try {
          const theme = localStorage.getItem('color-theme');
          if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark')
          }
        } catch (e) {
          // Fallback to system preference if localStorage is not available
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          }
        }
      }

      // Initial load
      applyTheme();

      // Handle View Transitions
      document.addEventListener('astro:before-swap', (ev) => {
        try {
          const theme = localStorage.getItem('color-theme');
          const isDark = theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (isDark) {
            ev.newDocument.documentElement.classList.add('dark');
          } else {
            ev.newDocument.documentElement.classList.remove('dark');
          }
        } catch (e) {
          // Fallback to system preference
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            ev.newDocument.documentElement.classList.add('dark');
          }
        }
      });

      // Secondary check for robustness
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
	</head>
	<body class="bg-white dark:bg-slate-950 text-slate-800 dark:text-slate-100 font-[Inter,sans-serif] antialiased transition-colors duration-300">
		<div class="min-h-screen flex flex-col">
			<!-- Header Component -->
			<Header />

			<!-- Main Content -->
			<main class="flex-1">
				<slot />
			</main>

			<!-- Footer Component -->
			<Footer />
		</div>

		<!-- Scroll Reveal Observer -->
		<script>
		let currentObserver: IntersectionObserver | null = null;

			function setupRevealObserver() {
				if (currentObserver) currentObserver.disconnect();

				const reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');

				currentObserver = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
						}
					});
				}, {
					threshold: 0.1,
					rootMargin: '0px 0px -50px 0px'
				});

				reveals.forEach(el => currentObserver!.observe(el));
			}

			// Cursor glow effect
			function setupCursorGlow() {
				document.querySelectorAll('.cursor-glow').forEach(el => {
					el.addEventListener('mousemove', (e) => {
						const rect = (el as HTMLElement).getBoundingClientRect();
						const x = e.clientX - rect.left;
						const y = e.clientY - rect.top;
						(el as HTMLElement).style.setProperty('--glow-x', `${x}px`);
						(el as HTMLElement).style.setProperty('--glow-y', `${y}px`);
						const before = (el as HTMLElement).querySelector('.glow-indicator') as HTMLElement;
						if (before) {
							before.style.left = `${x}px`;
							before.style.top = `${y}px`;
						}
					});
				});
			}

			// Setup on initial load
			setupRevealObserver();
			setupCursorGlow();

			// Load Keep Android Open banner on initial page load
			const initialScript = document.createElement('script');
			initialScript.src = 'https://keepandroidopen.org/banner.js?size=mini';
			initialScript.id = 'kao-banner-script';
			document.body.insertBefore(initialScript, document.body.firstChild);

			// Re-setup after View Transitions
			document.addEventListener('astro:after-swap', () => {
				setupRevealObserver();
				setupCursorGlow();

				// Clean up any existing banners and scripts
				const existingScript = document.getElementById('kao-banner-script');
				if (existingScript) {
					existingScript.remove();
				}

				// Remove all existing banners
				document.querySelectorAll('.kao-banner').forEach(banner => banner.remove());

				// Load banner after a small delay to ensure DOM is ready
				setTimeout(() => {
					const newScript = document.createElement('script');
					newScript.src = 'https://keepandroidopen.org/banner.js?size=mini';
					newScript.id = 'kao-banner-script';
					document.body.insertBefore(newScript, document.body.firstChild);
				}, 100);
			});
		</script>
	</body>
</html>
